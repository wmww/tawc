    <string name="install_method_label">Install method</string>
    <string name="install_method_tawcroot_recommended">tawcroot (recommended)</string>
    <string name="install_method_proot">proot</string>
    <string name="install_method_chroot_requires_root">chroot (requires root)</string>
    <string name="install_root_unavailable">root (su) not available &#8212; pick proot or tawcroot, or grant Magisk root.</string>
    <string name="install_method_info_tawcroot_title">tawcroot (recommended)</string>
    <string name="install_method_info_tawcroot_body">Custom systrap-based syscall emulator written for TAWC. Like proot it needs no root, but uses a more efficient ptrace alternative and is built specifically to handle the Wayland / GPU paths the compositor needs. Default for new installs and the only officially supported method.</string>
    <string name="install_method_info_proot_title">proot (dev only)</string>
    <string name="install_method_info_proot_body">Userspace chroot via the Termux fork of proot. Rootless and broadly compatible &#8212; pacman, package builds and most desktop apps work. Slower than tawcroot because every syscall is intercepted via ptrace. Available in debug builds for comparison; not shipped to release users.</string>
    <string name="install_method_info_chroot_title">chroot (requires root, dev only)</string>
    <string name="install_method_info_chroot_body">Real Linux chroot via su. Fastest path with no syscall translation overhead, but only works on rooted devices (Magisk / Phh-style su). The chroot mounts /apex, /vendor, /system and /linkerconfig from Android so libhybris GPU drivers can resolve their dependencies. Available in debug builds; not shipped to release users.</string>


<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <!-- Bootstrap tarballs are downloaded directly by the install package. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- CompositorService keeps the compositor thread + Wayland socket
         alive across Activity lifecycles; specialUse is the correct
         foregroundServiceType for a desktop compositor on Android 14+
         (none of the standard types fit). InstallationService runs the
         long-running install/uninstall flow as dataSync. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      extractNativeLibs="true": the rootless install method ships proot
      as jniLibs/<abi>/libproot.so and exec's it from nativeLibraryDir.
      execve needs a real on-disk inode, which only happens when the OS
      extracts native libs out of the APK. Without this attribute, AGP
      defaults to page-aligned-in-APK loading (good for dlopen, useless
      for exec). Same applies to libcompositor.so today (it's dlopen'd
      via System.loadLibrary so it'd work either way), but we don't want
      the default to ever shadow the proot binary's executability.
    -->
    <application
        android:name=".TawcApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="TAWC"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Tawc"
        android:extractNativeLibs="true">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- CompositorActivity hosts one window. The combination of
             documentLaunchMode="intoExisting", taskAffinity="" and a
             unique tawc://activity/<id> URI per launch makes Android
             treat each activityId as its own "document," giving each
             window a separate card in recents. The only launch path is
             the reverse-JNI spawnActivity callback in NativeBridge.kt,
             which uses an explicit Intent(ctx, CompositorActivity)
             with the URI as data — no intent-filter or exported needed.
             See notes/multi-activity.md. -->
        <activity
            android:name=".compositor.CompositorActivity"
            android:exported="false"
            android:theme="@style/Theme.Tawc.Compositor"
            android:documentLaunchMode="intoExisting"
            android:taskAffinity=""
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <service
            android:name=".compositor.CompositorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="wayland_compositor" />
        </service>

        <activity
            android:name=".install.InstallActivity"
            android:exported="false"
            android:label="Install distro" />

        <activity
            android:name=".install.DistroInfoActivity"
            android:exported="false"
            android:label="Distro info" />

        <activity
            android:name=".install.InstallMethodInfoActivity"
            android:exported="false"
            android:label="Install methods" />

        <activity
            android:name=".tasks.TaskManagerActivity"
            android:exported="false"
            android:label="Task manager" />

        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="Settings" />

        <!-- Generic per-operation log viewer. Pure viewer: opening it
             never triggers any operation. Exported=true so an
             am start with operationId from adb can attach to a running
             op (e.g. one started via the dev exec broker). -->
        <activity
            android:name=".ops.LogScreenActivity"
            android:exported="true"
            android:label="Operation log" />

        <!-- Notification "Cancel" action target. Looks up the named op
             in OperationsRegistry and calls Operation.cancel(). Bypasses
             cancelConfirmation — a notification-action tap is itself the
             deliberate decision. PendingIntents target this receiver via
             explicit ComponentName, so no intent-filter is needed. -->
        <receiver
            android:name=".ops.CancelOperationReceiver"
            android:exported="false" />

        <activity
            android:name=".launcher.LauncherActivity"
            android:exported="false"
            android:label="Launcher"
            android:theme="@style/Theme.Tawc.Launcher"
            android:windowSoftInputMode="stateVisible|adjustResize" />

        <service
            android:name=".install.InstallationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>

Disable Mesa's `DETECT_OS_ANDROID` even when building with the NDK.
The macro flips a chunk of util/ over to AOSP-internal headers
(`<cutils/trace.h>`, `<log/log.h>`) which aren't in the NDK sysroot —
we don't ship Android tracing or AOSP `liblog`. Forcing the macro
off keeps Mesa on its plain Linux/POSIX paths.

Vendored from termux-packages mesa/0000-disable-android-detection.patch
with proper `---` lines so `patch -p1` accepts it.

--- a/src/util/detect_os.h
+++ b/src/util/detect_os.h
@@ -24,7 +24,7 @@
  * Android defines __linux__, so DETECT_OS_LINUX and DETECT_OS_POSIX will
  * also be defined.
  */
-#if defined(__ANDROID__)
+#if 0
 #define DETECT_OS_ANDROID 1
 #endif

--- a/include/vulkan/vk_android_native_buffer.h
+++ b/include/vulkan/vk_android_native_buffer.h
@@ -17,7 +17,7 @@
  * system rather the build target.
  */

-#if defined(__ANDROID__) || defined(ANDROID)
+#if 0

 #include <cutils/native_handle.h>
 #if ANDROID_API_LEVEL < 28

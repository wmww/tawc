#!/data/data/com.termux/files/usr/bin/bash
# Create an Arch Linux ARM chroot on a rooted Android device.
# Run from Termux. Requires root (su) and an internet connection.
# Safe to re-run -- skips completed steps.
# Usage: ./arch-chroot-create

set -euo pipefail

# Ensure Ctrl+C kills chroot processes too
cleanup() {
    echo ""
    echo "==> Interrupted. Killing chroot processes..."
    su -c "pkill -f 'pacman' 2>/dev/null" || true
    exit 1
}
trap cleanup INT

CHROOT_DIR="/data/local/arch-chroot"
TARBALL_URL="http://os.archlinuxarm.org/os/ArchLinuxARM-aarch64-latest.tar.gz"
TARBALL="/data/data/com.termux/files/home/archlinux-aarch64.tar.gz"

# Ensure curl is available in Termux
if ! command -v curl &>/dev/null; then
    echo "==> Installing curl..."
    pkg install -y curl
fi

# Step 1: Download tarball (skip if already downloaded or already extracted)
if su -c "[ -d '$CHROOT_DIR/usr' ]"; then
    echo "==> Chroot already extracted, skipping download"
elif [ -f "$TARBALL" ]; then
    echo "==> Tarball already downloaded, skipping download"
else
    echo "==> Downloading Arch Linux ARM rootfs (~200MB)..."
    curl -L -o "$TARBALL" "$TARBALL_URL"
fi

# Step 2: Extract (skip if already done)
if su -c "[ -d '$CHROOT_DIR/usr' ]"; then
    echo "==> Chroot already extracted, skipping"
else
    echo "==> Extracting to $CHROOT_DIR..."
    su -c "mkdir -p '$CHROOT_DIR'"
    su -c "tar xzf '$TARBALL' -C '$CHROOT_DIR' 2>&1 | tail -1 || true"
fi

# Tarball is kept for re-runs. Delete manually if you want to reclaim ~200MB.

# Step 4: Configure DNS
echo "==> Configuring DNS..."
su -c "rm -f $CHROOT_DIR/etc/resolv.conf"
echo "nameserver 8.8.8.8" | su -c "tee $CHROOT_DIR/etc/resolv.conf >/dev/null"

# Step 5: Configure pacman
echo "==> Configuring pacman (disable signature checking and sandbox for Android)..."
su -c "sed -i 's/^SigLevel.*/SigLevel = Never/' '$CHROOT_DIR/etc/pacman.conf'"
# Disable Landlock sandbox and user switching (not supported in Android chroot)
# Disable disk space check (statvfs fails on Android chroot mounts)
# Must be in [options] section, so insert right after SigLevel
su -c "grep -q '^DisableSandbox' '$CHROOT_DIR/etc/pacman.conf' || sed -i '/^SigLevel/a DisableSandbox' '$CHROOT_DIR/etc/pacman.conf'"
su -c "sed -i 's/^CheckSpace/#CheckSpace/' '$CHROOT_DIR/etc/pacman.conf'"
# Skip kernel/firmware packages -- useless in a chroot
su -c "grep -q '^IgnorePkg' '$CHROOT_DIR/etc/pacman.conf' || sed -i '/#CheckSpace/a IgnorePkg = linux linux-aarch64 linux-firmware linux-firmware-*' '$CHROOT_DIR/etc/pacman.conf'"

# Step 6: Set up bind mounts
echo "==> Setting up bind mounts..."
su -c "mkdir -p '$CHROOT_DIR/dev' '$CHROOT_DIR/proc' '$CHROOT_DIR/sys' \
    '$CHROOT_DIR/vendor' '$CHROOT_DIR/system' '$CHROOT_DIR/system_ext' \
    '$CHROOT_DIR/dev/pts' \
    '$CHROOT_DIR/dev/binderfs' '$CHROOT_DIR/apex' '$CHROOT_DIR/linkerconfig'"
for pair in /dev:/dev /dev/pts:/dev/pts /dev/binderfs:/dev/binderfs /proc:/proc /sys:/sys /vendor:/vendor /system:/system /system_ext:/system_ext /linkerconfig:/linkerconfig; do
    src="${pair%%:*}"
    dst="$CHROOT_DIR${pair##*:}"
    su -c "mountpoint -q '$dst' 2>/dev/null || mount --bind '$src' '$dst'"
done
# /apex needs recursive bind mount because each APEX is a separate loop mount.
# Plain mount --bind gives empty directories for the individual APEXes.
su -c "mountpoint -q '$CHROOT_DIR/apex' 2>/dev/null || mount --rbind /apex '$CHROOT_DIR/apex'"

# Step 7: Initialize pacman keyring and update (skip if base-devel already installed)
if su -c "chroot '$CHROOT_DIR' /bin/bash -c 'command -v make'" &>/dev/null; then
    echo "==> base-devel already installed, skipping pacman init/update"
else
    # Write a setup script inside the chroot and run it directly.
    # Using exec chains so Ctrl+C propagates properly.
    su -c "cat > '$CHROOT_DIR/tmp/setup.sh' << 'SETUP'
#!/bin/bash
set -e
echo '==> Initializing pacman keyring...'
pacman-key --init
echo '==> Updating system...'
pacman -Syu --noconfirm
echo '==> Installing base development tools...'
pacman -S --noconfirm --needed base-devel git
rm -f /tmp/setup.sh
SETUP
chmod 755 '$CHROOT_DIR/tmp/setup.sh'"
    su -c "exec chroot '$CHROOT_DIR' /tmp/setup.sh"
fi

echo ""
echo "==> Done. Chroot created at $CHROOT_DIR"
echo "    Run arch-chroot to enter it."
echo "    Run arch-chroot-destroy to remove it."

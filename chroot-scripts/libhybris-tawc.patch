@@ -2813,9 +2869,51 @@ void* _hybris_hook_android_dlopen_ext(const char* filename, int flag, const void
 {
     TRACE("filename %s, flag %d, extinfo %p", filename, flag, extinfo);
 
+    /* android_dlextinfo has a library_namespace field (at offset 48 on aarch64)
+     * that specifies a linker namespace like "sphal". On stock Android this is
+     * obtained from android_get_exported_namespace(). libhybris's linker may
+     * not support these namespaces, causing HAL loading to fail.
+     * If a namespace is set, strip it and fall back to regular dlopen which
+     * searches the configured library path. */
+    if (extinfo != NULL) {
+        /* android_dlextinfo layout:
+         *   uint64_t flags;        // offset 0
+         *   void* reserved_addr;   // offset 8
+         *   size_t reserved_size;  // offset 16
+         *   int relro_fd;          // offset 24
+         *   int library_fd;        // offset 28
+         *   off64_t library_fd_offset; // offset 32
+         *   struct android_namespace_t* library_namespace; // offset 40-48
+         * ANDROID_DLEXT_USE_NAMESPACE flag = 0x200
+         */
+        uint64_t ext_flags = *(const uint64_t*)extinfo;
+        if (ext_flags & 0x200) {
+            /* Namespace specified -- strip it and use regular dlopen */
+            return _android_dlopen(filename, flag);
+        }
+    }
+
     return _android_dlopen_ext(filename, flag, extinfo);
 }
 
+/* Hook for android_load_sphal_library: used by HIDL passthrough HAL loading
+ * (e.g. gralloc mapper). On stock Android this does a dlopen with the "sphal"
+ * linker namespace. In libhybris we redirect to our own android_dlopen which
+ * searches the configured library paths including /vendor/lib64/hw/. */
+void* _hybris_hook_android_load_sphal_library(const char* name, int flag)
+{
+    TRACE("name %s, flag %d", name, flag);
+    return _android_dlopen(name, flag);
+}
+
+/* Matching unload hook */
+int _hybris_hook_android_unload_sphal_library(void* handle)
+{
+    TRACE("handle %p", handle);
+    /* Just do nothing - the library stays loaded */
+    return 0;
+}

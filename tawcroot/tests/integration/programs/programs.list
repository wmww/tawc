# Test fixture binary names. One per line; lines starting with '#' and
# blank lines are ignored. Read by tawcroot/Makefile and tawcroot/build.sh
# as the single source of truth for:
#
#   - the `fixtures` Makefile target's dependency list
#   - the `-DTAWCROOT_<UPPERCASE_NAME>_BIN=<prefix>/programs/<name>`
#     defines passed to the cleat test orchestrator
#
# Each fixture's source lives at tests/integration/programs/<name>{_<arch>.S,.c}
# and its on-device path is $TAWC_SCRATCH/programs/<name>.
#
# Adding a new fixture: append the name here, then add a build rule to
# tawcroot/Makefile and a `build_static`/`build_dynamic` line to
# tawcroot/build-fixtures.sh (those vary per-fixture so they're not derived).
static_exit42
static_argc_random
static_execve_exit42
static_open_creat_argv1
static_open_rdonly_argv1
static_sleep_open_creat_argv1
static_fork_open_argv1
static_fork_exec_argv1
static_fork_closefrom_exec_argv1
static_fexecve_argv1
static_unix_bind_argv1
static_check_proc_self_fd
static_check_proc_exe_argv0
static_io_uring_deny
dynamic_exit42
dynamic_argv_check
dynamic_big_stack

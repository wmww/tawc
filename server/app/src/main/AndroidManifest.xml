<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:glEsVersion="0x00020000" android:required="true" />

    <!-- Bootstrap tarballs are downloaded directly by the install package. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- CompositorService keeps the compositor thread + Wayland socket
         alive across Activity lifecycles; specialUse is the correct
         foregroundServiceType for a desktop compositor on Android 14+
         (none of the standard types fit). InstallationService runs the
         long-running install/uninstall flow as dataSync. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="false"
        android:label="tawc"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Tawc">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- CompositorActivity hosts one window. The combination of
             documentLaunchMode="intoExisting", taskAffinity="" and a
             unique tawc://activity/<id> URI per launch makes Android
             treat each activityId as its own "document," giving each
             window a separate card in recents. Same URI → same task
             (so MainActivity launches from the launcher reuse the
             existing primary instance). See notes/multi-activity.md. -->
        <activity
            android:name=".compositor.CompositorActivity"
            android:exported="true"
            android:theme="@style/Theme.Tawc.Compositor"
            android:documentLaunchMode="intoExisting"
            android:taskAffinity=""
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="tawc" android:host="activity" />
            </intent-filter>
        </activity>

        <service
            android:name=".compositor.CompositorService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="wayland_compositor" />
        </service>

        <activity
            android:name=".install.ManageInstallationsActivity"
            android:exported="true"
            android:label="Manage installations" />

        <service
            android:name=".install.InstallationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- INSTALL/UNINSTALL aren't broadcasts: they need a foreground
             service start, which background receivers can't reliably do
             on Android 14+. Use `am start` into ManageInstallationsActivity
             with the autoAction extra instead. See notes/installation.md. -->
        <receiver
            android:name=".install.InstallationCommandReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="me.phie.tawc.install.RUN" />
                <action android:name="me.phie.tawc.install.LIST" />
            </intent-filter>
        </receiver>

    </application>

</manifest>

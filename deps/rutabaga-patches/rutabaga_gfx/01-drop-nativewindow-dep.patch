+/// Embedder hook for the PLATFORM_AHB branch of `Gfxstream::export_blob`.
+///
+/// Input is `stream_renderer_handle.os_handle` for a PLATFORM_AHB result,
+/// i.e. an `AHardwareBuffer*` cast to `i64` (the gfxstream renderer's own
+/// in-process pointer; the AHB's refcount is still owned by the gfxstream
+/// side at call time — embedders that want it to outlive the gfxstream
+/// resource must take their own ref via `AHardwareBuffer_acquire`).
+///
+/// Return is a raw fd that the rutabaga server will ship to the kumquat
+/// client via SCM_RIGHTS. The wrapper turns it into a `MesaHandle` of
+/// type `MEM_DMABUF`. The expected callback shape mirrors AOSP's
+/// `nativewindow` path: pull the AHB's backing dmabuf fd out of its
+/// `native_handle_t` and return a dup owned by rutabaga.
+///
+/// `Err(())` becomes `RutabagaError::InvalidResourceId` to the caller —
+/// matches the upstream "we have an AHB we can't ship over IPC" failure
+/// mode rutabaga returns on systems with no nativewindow shim.
+pub type AhbExportFn = fn(ahb_os_handle: i64) -> Result<i32, ()>;
+
+static AHB_EXPORT_CB: OnceLock<AhbExportFn> = OnceLock::new();
+
+/// Install the AHB export hook. First call wins; subsequent calls
+/// are silently rejected (matches `OnceLock::set`). Returns `Ok(())` on
+/// successful install, `Err(())` if a callback was already set.
+pub fn set_ahb_export_callback(cb: AhbExportFn) -> Result<(), ()> {
+    AHB_EXPORT_CB.set(cb).map_err(|_| ())
+}

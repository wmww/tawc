@@ -0,0 +1,38 @@
+<?xml version="1.0" encoding="UTF-8"?>
+<protocol name="tawc_gfxstream">
+
+  <copyright>
+    Copyright (c) tawc authors.
+
+    SPDX-License-Identifier: MIT
+  </copyright>
+
+  <description summary="tawc gfxstream-bridge present protocol (chroot/client side)">
+    This file mirrors `compositor/protocols/tawc_gfxstream.xml` from the
+    tawc compositor source tree. It is duplicated here so the Mesa build
+    is self-contained — `mod_wl.scan_xml` runs on this file at Mesa
+    build time to generate the client-side bindings used by
+    `gfxstream_vk_tawc_wsi.cpp`. Keep the two copies in sync; the
+    compositor's copy is the source of truth.
+  </description>
+
+  <interface name="tawc_gfxstream" version="1">
+    <description summary="bind gfxstream ColorBuffer resources as wl_buffers"/>
+
+    <enum name="error">
+      <entry name="unknown_colorbuffer" value="0"/>
+      <entry name="not_ahb_backed" value="1"/>
+    </enum>
+
+    <request name="create_buffer">
+      <arg name="id" type="new_id" interface="wl_buffer"/>
+      <arg name="colorbuffer_id" type="uint"/>
+      <arg name="width" type="int"/>
+      <arg name="height" type="int"/>
+      <arg name="format" type="uint"/>
+    </request>
+
+    <request name="destroy" type="destructor"/>
+  </interface>
+
+</protocol>

+/*
+ * Copyright (c) tawc authors.
+ * SPDX-License-Identifier: MIT
+ *
+ * Custom Vulkan WSI for the tawc gfxstream bridge.
+ *
+ * Presents gfxstream ColorBuffer ids over the `tawc_gfxstream`
+ * Wayland protocol. The compositor resolves each id to an AHB in the
+ * in-process gfxstream host renderer.
+ *
+ * `allocate_swapchain_image()` is still a stub. It must create a
+ * kumquat render-target blob, import it into VkDeviceMemory with
+ * `VkImportColorBufferGOOGLE`, and bind that memory to the swapchain
+ * VkImage. See issues/gfxstream-wsi-swapchain-alloc-blocker.md.
+ */
+
+#include <pthread.h>
+#include <wayland-client.h>
+
+#include <algorithm>
+#include <cstring>
+#include <new>
+#include <vector>
+
+#include "tawc_gfxstream-client-protocol.h"
+
+#include "gfxstream_vk_entrypoints.h"
+#include "gfxstream_vk_private.h"
+
+#include "util/log.h"
+#include "vk_alloc.h"
+#include "vk_object.h"
+
+#include <vulkan/vk_icd.h>
+
+namespace gfxstream {
+namespace vk {
+
+// ---------------------------------------------------------------------------
+// VkSurfaceKHR
+// ---------------------------------------------------------------------------
+//
+// Surfaces are allocated against the VkInstance and outlive any device.
+// We allocate a flat struct (not a vk_object) and round-trip the
+// pointer; the only consumers are our own entrypoints below. The first
+// member is VkIcdSurfaceWayland so the loader's introspection can still
+// reach the wl_display/wl_surface fields via the standard offset.
+
+struct gfxstream_vk_surface {
+    VkIcdSurfaceWayland icd;  // icd.base.platform = VK_ICD_WSI_PLATFORM_WAYLAND
+};
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_CreateWaylandSurfaceKHR(
+    VkInstance _instance, const VkWaylandSurfaceCreateInfoKHR* pCreateInfo,
+    const VkAllocationCallbacks* pAllocator, VkSurfaceKHR* pSurface) {
+    VK_FROM_HANDLE(gfxstream_vk_instance, instance, _instance);
+
+    gfxstream_vk_surface* surface = (gfxstream_vk_surface*)vk_zalloc2(
+        &instance->vk.alloc, pAllocator, sizeof(*surface), 8,
+        VK_SYSTEM_ALLOCATION_SCOPE_OBJECT);
+    if (!surface) return VK_ERROR_OUT_OF_HOST_MEMORY;
+
+    surface->icd.base.platform = VK_ICD_WSI_PLATFORM_WAYLAND;
+    surface->icd.display = pCreateInfo->display;
+    surface->icd.surface = pCreateInfo->surface;
+
+    *pSurface = (VkSurfaceKHR)(uintptr_t)surface;
+    return VK_SUCCESS;
+}
+
+extern "C" VKAPI_ATTR void VKAPI_CALL gfxstream_vk_DestroySurfaceKHR(
+    VkInstance _instance, VkSurfaceKHR _surface, const VkAllocationCallbacks* pAllocator) {
+    VK_FROM_HANDLE(gfxstream_vk_instance, instance, _instance);
+    if (!_surface) return;
+    gfxstream_vk_surface* surface = (gfxstream_vk_surface*)(uintptr_t)_surface;
+    vk_free2(&instance->vk.alloc, pAllocator, surface);
+}
+
+// ---------------------------------------------------------------------------
+// Surface caps / formats / present modes
+// ---------------------------------------------------------------------------
+//
+// Hardcoded to keep this layer tiny. The compositor re-imports each
+// frame's AHB by colorbuffer_id; there is no display server to negotiate
+// against and the AHB import path doesn't care about presentation
+// transforms.
+
+static const VkFormat kSupportedFormats[] = {
+    VK_FORMAT_B8G8R8A8_UNORM,
+    VK_FORMAT_R8G8B8A8_UNORM,
+};
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetPhysicalDeviceSurfaceSupportKHR(
+    VkPhysicalDevice /*physicalDevice*/, uint32_t /*queueFamilyIndex*/, VkSurfaceKHR /*surface*/,
+    VkBool32* pSupported) {
+    *pSupported = VK_TRUE;
+    return VK_SUCCESS;
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetPhysicalDeviceSurfaceCapabilitiesKHR(
+    VkPhysicalDevice /*physicalDevice*/, VkSurfaceKHR /*_surface*/,
+    VkSurfaceCapabilitiesKHR* pSurfaceCapabilities) {
+    pSurfaceCapabilities->minImageCount = 2;
+    pSurfaceCapabilities->maxImageCount = 0;
+    pSurfaceCapabilities->currentExtent = (VkExtent2D){0xFFFFFFFFu, 0xFFFFFFFFu};
+    pSurfaceCapabilities->minImageExtent = (VkExtent2D){1, 1};
+    pSurfaceCapabilities->maxImageExtent = (VkExtent2D){4096, 4096};
+    pSurfaceCapabilities->maxImageArrayLayers = 1;
+    pSurfaceCapabilities->supportedTransforms = VK_SURFACE_TRANSFORM_IDENTITY_BIT_KHR;
+    pSurfaceCapabilities->currentTransform = VK_SURFACE_TRANSFORM_IDENTITY_BIT_KHR;
+    pSurfaceCapabilities->supportedCompositeAlpha =
+        VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR | VK_COMPOSITE_ALPHA_INHERIT_BIT_KHR;
+    pSurfaceCapabilities->supportedUsageFlags = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT |
+                                                VK_IMAGE_USAGE_TRANSFER_DST_BIT |
+                                                VK_IMAGE_USAGE_TRANSFER_SRC_BIT;
+    return VK_SUCCESS;
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetPhysicalDeviceSurfaceCapabilities2KHR(
+    VkPhysicalDevice physicalDevice, const VkPhysicalDeviceSurfaceInfo2KHR* pSurfaceInfo,
+    VkSurfaceCapabilities2KHR* pSurfaceCapabilities) {
+    return gfxstream_vk_GetPhysicalDeviceSurfaceCapabilitiesKHR(
+        physicalDevice, pSurfaceInfo->surface, &pSurfaceCapabilities->surfaceCapabilities);
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetPhysicalDeviceSurfaceFormatsKHR(
+    VkPhysicalDevice /*physicalDevice*/, VkSurfaceKHR /*_surface*/, uint32_t* pSurfaceFormatCount,
+    VkSurfaceFormatKHR* pSurfaceFormats) {
+    const uint32_t format_count = sizeof(kSupportedFormats) / sizeof(kSupportedFormats[0]);
+    if (!pSurfaceFormats) {
+        *pSurfaceFormatCount = format_count;
+        return VK_SUCCESS;
+    }
+    const uint32_t to_write = std::min(*pSurfaceFormatCount, format_count);
+    for (uint32_t i = 0; i < to_write; i++) {
+        pSurfaceFormats[i].format = kSupportedFormats[i];
+        pSurfaceFormats[i].colorSpace = VK_COLOR_SPACE_SRGB_NONLINEAR_KHR;
+    }
+    *pSurfaceFormatCount = to_write;
+    return to_write < format_count ? VK_INCOMPLETE : VK_SUCCESS;
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetPhysicalDeviceSurfaceFormats2KHR(
+    VkPhysicalDevice /*physicalDevice*/, const VkPhysicalDeviceSurfaceInfo2KHR* /*pSurfaceInfo*/,
+    uint32_t* pSurfaceFormatCount, VkSurfaceFormat2KHR* pSurfaceFormats) {
+    const uint32_t format_count = sizeof(kSupportedFormats) / sizeof(kSupportedFormats[0]);
+    if (!pSurfaceFormats) {
+        *pSurfaceFormatCount = format_count;
+        return VK_SUCCESS;
+    }
+    const uint32_t to_write = std::min(*pSurfaceFormatCount, format_count);
+    for (uint32_t i = 0; i < to_write; i++) {
+        pSurfaceFormats[i].surfaceFormat.format = kSupportedFormats[i];
+        pSurfaceFormats[i].surfaceFormat.colorSpace = VK_COLOR_SPACE_SRGB_NONLINEAR_KHR;
+    }
+    *pSurfaceFormatCount = to_write;
+    return to_write < format_count ? VK_INCOMPLETE : VK_SUCCESS;
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetPhysicalDeviceSurfacePresentModesKHR(
+    VkPhysicalDevice /*physicalDevice*/, VkSurfaceKHR /*_surface*/, uint32_t* pPresentModeCount,
+    VkPresentModeKHR* pPresentModes) {
+    static const VkPresentModeKHR kModes[] = {VK_PRESENT_MODE_FIFO_KHR,
+                                              VK_PRESENT_MODE_MAILBOX_KHR};
+    const uint32_t mode_count = sizeof(kModes) / sizeof(kModes[0]);
+    if (!pPresentModes) {
+        *pPresentModeCount = mode_count;
+        return VK_SUCCESS;
+    }
+    const uint32_t to_write = std::min(*pPresentModeCount, mode_count);
+    for (uint32_t i = 0; i < to_write; i++) pPresentModes[i] = kModes[i];
+    *pPresentModeCount = to_write;
+    return to_write < mode_count ? VK_INCOMPLETE : VK_SUCCESS;
+}
+
+// ---------------------------------------------------------------------------
+// Wayland binding: registry walk to find tawc_gfxstream
+// ---------------------------------------------------------------------------
+
+namespace {
+
+struct registry_state {
+    struct tawc_gfxstream* tawc = nullptr;
+};
+
+void registry_global(void* data, struct wl_registry* registry, uint32_t name,
+                     const char* interface, uint32_t /*version*/) {
+    auto* st = static_cast<registry_state*>(data);
+    if (!std::strcmp(interface, "tawc_gfxstream")) {
+        st->tawc = static_cast<struct tawc_gfxstream*>(
+            wl_registry_bind(registry, name, &tawc_gfxstream_interface, 1));
+    }
+}
+
+void registry_global_remove(void* /*data*/, struct wl_registry* /*registry*/,
+                            uint32_t /*name*/) {}
+
+const struct wl_registry_listener kRegistryListener = {
+    registry_global,
+    registry_global_remove,
+};
+
+}  // anonymous namespace
+
+// ---------------------------------------------------------------------------
+// Swapchain
+// ---------------------------------------------------------------------------
+
+struct gfxstream_vk_swapchain_image {
+    VkImage image = VK_NULL_HANDLE;
+    VkDeviceMemory memory = VK_NULL_HANDLE;
+    uint32_t colorbuffer_id = 0;
+    bool acquired = false;
+    struct wl_buffer* wl_buffer = nullptr;
+};
+
+struct gfxstream_vk_swapchain {
+    struct vk_object_base base;
+
+    gfxstream_vk_device* device = nullptr;
+    VkAllocationCallbacks alloc = {};
+
+    VkExtent2D extent = {0, 0};
+    VkFormat format = VK_FORMAT_UNDEFINED;
+    VkImageUsageFlags usage = 0;
+    VkPresentModeKHR present_mode = VK_PRESENT_MODE_FIFO_KHR;
+
+    // Share the app's wl_display, but keep WSI proxies on a private
+    // event queue so release handling does not consume app events.
+    struct wl_display* display = nullptr;          // shared with the app -- borrowed
+    struct wl_surface* surface = nullptr;          // ditto
+    struct wl_event_queue* queue = nullptr;        // owned
+    struct wl_display* display_wrapper = nullptr;  // proxy on `queue`
+    struct wl_registry* registry = nullptr;        // owned
+    struct tawc_gfxstream* tawc = nullptr;         // owned
+
+    pthread_mutex_t mutex = PTHREAD_MUTEX_INITIALIZER;
+
+    std::vector<gfxstream_vk_swapchain_image> images;
+};
+
+VK_DEFINE_NONDISP_HANDLE_CASTS(gfxstream_vk_swapchain, base, VkSwapchainKHR,
+                               VK_OBJECT_TYPE_SWAPCHAIN_KHR)
+
+namespace {
+
+// TODO: allocate a render-target ColorBuffer and import it with
+// VkImportColorBufferGOOGLE. Fail fast until that path exists.
+VkResult allocate_swapchain_image(gfxstream_vk_device* /*device*/,
+                                  const VkSwapchainCreateInfoKHR* /*createInfo*/,
+                                  gfxstream_vk_swapchain_image* out) {
+    out->image = VK_NULL_HANDLE;
+    out->memory = VK_NULL_HANDLE;
+    out->colorbuffer_id = 0;
+    mesa_loge(
+        "tawc_wsi: allocate_swapchain_image() is not implemented yet -- see "
+        "issues/gfxstream-wsi-swapchain-alloc-blocker.md.");
+    return VK_ERROR_INITIALIZATION_FAILED;
+}
+
+void free_swapchain_image(gfxstream_vk_device* device, gfxstream_vk_swapchain_image* img) {
+    if (img->wl_buffer) {
+        wl_buffer_destroy(img->wl_buffer);
+        img->wl_buffer = nullptr;
+    }
+    if (img->memory) {
+        gfxstream_vk_FreeMemory(gfxstream_vk_device_to_handle(device), img->memory, nullptr);
+        img->memory = VK_NULL_HANDLE;
+    }
+    if (img->image) {
+        gfxstream_vk_DestroyImage(gfxstream_vk_device_to_handle(device), img->image, nullptr);
+        img->image = VK_NULL_HANDLE;
+    }
+    img->colorbuffer_id = 0;
+    img->acquired = false;
+}
+
+}  // anonymous namespace
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_CreateSwapchainKHR(
+    VkDevice _device, const VkSwapchainCreateInfoKHR* pCreateInfo,
+    const VkAllocationCallbacks* pAllocator, VkSwapchainKHR* pSwapchain) {
+    VK_FROM_HANDLE(gfxstream_vk_device, device, _device);
+    gfxstream_vk_surface* surface = (gfxstream_vk_surface*)(uintptr_t)pCreateInfo->surface;
+
+    gfxstream_vk_swapchain* sc = (gfxstream_vk_swapchain*)vk_zalloc2(
+        &device->vk.alloc, pAllocator, sizeof(*sc), 8,
+        VK_SYSTEM_ALLOCATION_SCOPE_OBJECT);
+    if (!sc) return VK_ERROR_OUT_OF_HOST_MEMORY;
+
+    new (sc) gfxstream_vk_swapchain();
+    vk_object_base_init(&device->vk, &sc->base, VK_OBJECT_TYPE_SWAPCHAIN_KHR);
+    sc->device = device;
+    sc->alloc = pAllocator ? *pAllocator : device->vk.alloc;
+    sc->extent = pCreateInfo->imageExtent;
+    sc->format = pCreateInfo->imageFormat;
+    sc->usage = pCreateInfo->imageUsage;
+    sc->present_mode = pCreateInfo->presentMode;
+    sc->display = surface->icd.display;
+    sc->surface = surface->icd.surface;
+    pthread_mutex_init(&sc->mutex, nullptr);
+
+    sc->queue = wl_display_create_queue(sc->display);
+    if (!sc->queue) {
+        mesa_loge("tawc_wsi: failed to create wl_event_queue");
+        sc->~gfxstream_vk_swapchain();
+        vk_object_free(&device->vk, pAllocator, sc);
+        return VK_ERROR_INITIALIZATION_FAILED;
+    }
+    sc->display_wrapper =
+        static_cast<struct wl_display*>(wl_proxy_create_wrapper(sc->display));
+    if (!sc->display_wrapper) {
+        wl_event_queue_destroy(sc->queue);
+        sc->~gfxstream_vk_swapchain();
+        vk_object_free(&device->vk, pAllocator, sc);
+        return VK_ERROR_INITIALIZATION_FAILED;
+    }
+    wl_proxy_set_queue((struct wl_proxy*)sc->display_wrapper, sc->queue);
+
+    sc->registry = wl_display_get_registry(sc->display_wrapper);
+    if (!sc->registry) {
+        wl_proxy_wrapper_destroy(sc->display_wrapper);
+        wl_event_queue_destroy(sc->queue);
+        sc->~gfxstream_vk_swapchain();
+        vk_object_free(&device->vk, pAllocator, sc);
+        return VK_ERROR_INITIALIZATION_FAILED;
+    }
+
+    registry_state regst;
+    wl_registry_add_listener(sc->registry, &kRegistryListener, &regst);
+    wl_display_roundtrip_queue(sc->display, sc->queue);
+    sc->tawc = regst.tawc;
+    if (!sc->tawc) {
+        mesa_loge(
+            "tawc_wsi: compositor doesn't advertise tawc_gfxstream. "
+            "This bridge build needs the tawc compositor.");
+        wl_registry_destroy(sc->registry);
+        wl_proxy_wrapper_destroy(sc->display_wrapper);
+        wl_event_queue_destroy(sc->queue);
+        sc->~gfxstream_vk_swapchain();
+        vk_object_free(&device->vk, pAllocator, sc);
+        return VK_ERROR_INITIALIZATION_FAILED;
+    }
+
+    uint32_t image_count = pCreateInfo->minImageCount;
+    if (image_count < 2) image_count = 2;
+    if (image_count > 8) image_count = 8;
+
+    sc->images.resize(image_count);
+    for (uint32_t i = 0; i < image_count; i++) {
+        VkResult res = allocate_swapchain_image(device, pCreateInfo, &sc->images[i]);
+        if (res != VK_SUCCESS) {
+            for (uint32_t j = 0; j < i; j++) free_swapchain_image(device, &sc->images[j]);
+            sc->images.clear();
+            tawc_gfxstream_destroy(sc->tawc);
+            wl_registry_destroy(sc->registry);
+            wl_proxy_wrapper_destroy(sc->display_wrapper);
+            wl_event_queue_destroy(sc->queue);
+            sc->~gfxstream_vk_swapchain();
+            vk_object_free(&device->vk, pAllocator, sc);
+            return res;
+        }
+    }
+
+    *pSwapchain = gfxstream_vk_swapchain_to_handle(sc);
+    return VK_SUCCESS;
+}
+
+extern "C" VKAPI_ATTR void VKAPI_CALL gfxstream_vk_DestroySwapchainKHR(
+    VkDevice _device, VkSwapchainKHR _swapchain, const VkAllocationCallbacks* pAllocator) {
+    VK_FROM_HANDLE(gfxstream_vk_device, device, _device);
+    if (!_swapchain) return;
+    gfxstream_vk_swapchain* sc = gfxstream_vk_swapchain_from_handle(_swapchain);
+
+    for (auto& img : sc->images) free_swapchain_image(device, &img);
+    sc->images.clear();
+
+    if (sc->tawc) tawc_gfxstream_destroy(sc->tawc);
+    if (sc->registry) wl_registry_destroy(sc->registry);
+    if (sc->display_wrapper) wl_proxy_wrapper_destroy(sc->display_wrapper);
+    if (sc->queue) wl_event_queue_destroy(sc->queue);
+
+    pthread_mutex_destroy(&sc->mutex);
+
+    sc->~gfxstream_vk_swapchain();
+    vk_object_free(&device->vk, pAllocator, sc);
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_GetSwapchainImagesKHR(
+    VkDevice /*device*/, VkSwapchainKHR _swapchain, uint32_t* pSwapchainImageCount,
+    VkImage* pSwapchainImages) {
+    gfxstream_vk_swapchain* sc = gfxstream_vk_swapchain_from_handle(_swapchain);
+    const uint32_t avail = sc->images.size();
+    if (!pSwapchainImages) {
+        *pSwapchainImageCount = avail;
+        return VK_SUCCESS;
+    }
+    const uint32_t to_write = std::min(*pSwapchainImageCount, avail);
+    for (uint32_t i = 0; i < to_write; i++) pSwapchainImages[i] = sc->images[i].image;
+    *pSwapchainImageCount = to_write;
+    return to_write < avail ? VK_INCOMPLETE : VK_SUCCESS;
+}
+
+namespace {
+
+void drain_releases(gfxstream_vk_swapchain* sc) {
+    wl_display_dispatch_queue_pending(sc->display, sc->queue);
+}
+
+uint32_t pick_free_image(gfxstream_vk_swapchain* sc) {
+    for (uint32_t i = 0; i < sc->images.size(); i++) {
+        if (!sc->images[i].acquired) return i;
+    }
+    return UINT32_MAX;
+}
+
+VkResult signal_acquire(gfxstream_vk_device* device, VkSemaphore semaphore, VkFence fence) {
+    if (semaphore == VK_NULL_HANDLE && fence == VK_NULL_HANDLE) return VK_SUCCESS;
+    VkQueue queue = VK_NULL_HANDLE;
+    if (device->queue_count > 0) queue = gfxstream_vk_queue_to_handle(&device->queues[0]);
+    if (queue == VK_NULL_HANDLE) {
+        mesa_logw("tawc_wsi: no queue to signal acquire on");
+        return VK_SUCCESS;
+    }
+    const VkSubmitInfo submit = {
+        VK_STRUCTURE_TYPE_SUBMIT_INFO, nullptr, 0, nullptr, nullptr, 0, nullptr,
+        semaphore != VK_NULL_HANDLE ? 1u : 0u,
+        semaphore != VK_NULL_HANDLE ? &semaphore : nullptr,
+    };
+    return gfxstream_vk_QueueSubmit(queue, 1, &submit, fence);
+}
+
+}  // anonymous namespace
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_AcquireNextImageKHR(
+    VkDevice _device, VkSwapchainKHR _swapchain, uint64_t timeout, VkSemaphore semaphore,
+    VkFence fence, uint32_t* pImageIndex) {
+    VK_FROM_HANDLE(gfxstream_vk_device, device, _device);
+    gfxstream_vk_swapchain* sc = gfxstream_vk_swapchain_from_handle(_swapchain);
+
+    drain_releases(sc);
+
+    pthread_mutex_lock(&sc->mutex);
+    uint32_t idx = pick_free_image(sc);
+    if (idx == UINT32_MAX && timeout != 0) {
+        pthread_mutex_unlock(&sc->mutex);
+        wl_display_roundtrip_queue(sc->display, sc->queue);
+        pthread_mutex_lock(&sc->mutex);
+        idx = pick_free_image(sc);
+    }
+    if (idx == UINT32_MAX) {
+        pthread_mutex_unlock(&sc->mutex);
+        return VK_NOT_READY;
+    }
+    sc->images[idx].acquired = true;
+    pthread_mutex_unlock(&sc->mutex);
+
+    *pImageIndex = idx;
+    return signal_acquire(device, semaphore, fence);
+}
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_AcquireNextImage2KHR(
+    VkDevice _device, const VkAcquireNextImageInfoKHR* pAcquireInfo, uint32_t* pImageIndex) {
+    return gfxstream_vk_AcquireNextImageKHR(_device, pAcquireInfo->swapchain, pAcquireInfo->timeout,
+                                            pAcquireInfo->semaphore, pAcquireInfo->fence,
+                                            pImageIndex);
+}
+
+namespace {
+
+void buffer_release(void* data, struct wl_buffer* /*wl_buffer*/) {
+    auto* img = static_cast<gfxstream_vk_swapchain_image*>(data);
+    img->acquired = false;
+}
+
+const struct wl_buffer_listener kBufferListener = {
+    buffer_release,
+};
+
+uint32_t drm_fourcc_from_vk(VkFormat fmt) {
+    switch (fmt) {
+        case VK_FORMAT_B8G8R8A8_UNORM:
+        case VK_FORMAT_B8G8R8A8_SRGB:
+            return 0x34324241;  // DRM_FORMAT_ARGB8888
+        case VK_FORMAT_R8G8B8A8_UNORM:
+        case VK_FORMAT_R8G8B8A8_SRGB:
+            return 0x34324152;  // DRM_FORMAT_ABGR8888
+        default:
+            return 0;
+    }
+}
+
+}  // anonymous namespace
+
+extern "C" VKAPI_ATTR VkResult VKAPI_CALL gfxstream_vk_QueuePresentKHR(
+    VkQueue _queue, const VkPresentInfoKHR* pPresentInfo) {
+    if (pPresentInfo->waitSemaphoreCount > 0) {
+        std::vector<VkPipelineStageFlags> stages(pPresentInfo->waitSemaphoreCount,
+                                                 VK_PIPELINE_STAGE_ALL_COMMANDS_BIT);
+        const VkSubmitInfo submit = {
+            VK_STRUCTURE_TYPE_SUBMIT_INFO, nullptr,
+            pPresentInfo->waitSemaphoreCount, pPresentInfo->pWaitSemaphores, stages.data(),
+            0, nullptr, 0, nullptr,
+        };
+        VkResult res = gfxstream_vk_QueueSubmit(_queue, 1, &submit, VK_NULL_HANDLE);
+        if (res != VK_SUCCESS) return res;
+    }
+    // The Wayland protocol carries no GPU fence, so don't let the
+    // compositor sample the AHB until gfxstream has finished the queue work.
+    VkResult wait_res = gfxstream_vk_QueueWaitIdle(_queue);
+    if (wait_res != VK_SUCCESS) return wait_res;
+
+    VkResult overall = VK_SUCCESS;
+    for (uint32_t i = 0; i < pPresentInfo->swapchainCount; i++) {
+        gfxstream_vk_swapchain* sc =
+            gfxstream_vk_swapchain_from_handle(pPresentInfo->pSwapchains[i]);
+        const uint32_t idx = pPresentInfo->pImageIndices[i];
+        if (idx >= sc->images.size()) {
+            overall = VK_ERROR_OUT_OF_DATE_KHR;
+            if (pPresentInfo->pResults) pPresentInfo->pResults[i] = VK_ERROR_OUT_OF_DATE_KHR;
+            continue;
+        }
+        gfxstream_vk_swapchain_image& img = sc->images[idx];
+
+        if (img.wl_buffer) {
+            wl_buffer_destroy(img.wl_buffer);
+            img.wl_buffer = nullptr;
+        }
+        img.wl_buffer = tawc_gfxstream_create_buffer(
+            sc->tawc, img.colorbuffer_id, sc->extent.width, sc->extent.height,
+            drm_fourcc_from_vk(sc->format));
+        if (!img.wl_buffer) {
+            overall = VK_ERROR_OUT_OF_HOST_MEMORY;
+            if (pPresentInfo->pResults) pPresentInfo->pResults[i] = VK_ERROR_OUT_OF_HOST_MEMORY;
+            continue;
+        }
+        wl_buffer_add_listener(img.wl_buffer, &kBufferListener, &img);
+
+        wl_surface_attach(sc->surface, img.wl_buffer, 0, 0);
+        wl_surface_damage_buffer(sc->surface, 0, 0, sc->extent.width, sc->extent.height);
+        wl_surface_commit(sc->surface);
+
+        wl_display_flush(sc->display);
+
+        if (pPresentInfo->pResults) pPresentInfo->pResults[i] = VK_SUCCESS;
+    }
+
+    return overall;
+}
+
+}  // namespace vk
+}  // namespace gfxstream
